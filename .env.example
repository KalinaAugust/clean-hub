# Google Sheets API Configuration
# Получите API ключ здесь: https://console.cloud.google.com/apis/credentials
REACT_APP_GOOGLE_SHEETS_API_KEY=your_api_key_here

# ID таблицы Google Sheets (из URL таблицы)
# Пример URL: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
REACT_APP_SPREADSHEET_ID=your_spreadsheet_id_here

# Диапазон ячеек для чтения (опционально, по умолчанию Sheet1!A1:Z100)
REACT_APP_SHEET_RANGE=Sheet1!A1:Z100
